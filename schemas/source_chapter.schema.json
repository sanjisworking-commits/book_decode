{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://accordingtologic.local/schemas/source_chapter.schema.json",
  "title": "SourceChapter",
  "description": "Per-chapter compatibility view derived from canonical book.json (schema 2.0).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "book_id",
    "chapter_id",
    "chapter_number",
    "chapter_title",
    "heading_hierarchy",
    "source_blocks"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "2.0" },
    "book_id": { "type": "string", "minLength": 1 },
    "chapter_id": { "type": "string", "minLength": 1 },
    "chapter_number": { "type": ["integer", "null"], "minimum": 1 },
    "chapter_title": { "type": "string" },
    "heading_hierarchy": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_blocks": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceBlock" }
    }
  },
  "$defs": {
    "sourceBlock": {
      "type": "object",
      "additionalProperties": true,
      "required": ["block_id", "block_type", "text", "order_index"],
      "properties": {
        "block_id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable ID: book_id.chapter_id.section_id.blockNNN"
        },
        "section_id": { "type": ["string", "null"] },
        "block_type": {
          "type": "string",
          "enum": [
            "heading",
            "paragraph",
            "quote",
            "table",
            "list",
            "list_item",
            "note",
            "image",
            "figure",
            "diagram",
            "equation",
            "code",
            "sidebar",
            "callout",
            "exercise",
            "summary",
            "warning",
            "example",
            "other"
          ]
        },
        "text": { "type": "string" },
        "order_index": { "type": "integer", "minimum": 0 },
        "book_id": { "type": "string" },
        "chapter_id": { "type": ["string", "null"] },
        "heading_path": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_ref": { "type": ["string", "null"] },
        "docling_index": { "type": ["integer", "null"] },
        "book_order_index": { "type": ["integer", "null"] },
        "metadata": { "type": "object" }
      }
    }
  }
}
