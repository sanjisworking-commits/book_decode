# According to Logic — Book Decode
# Copy to .env and fill in values. Do not commit real secrets.

# --- Application ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173

# --- Storage (MVP: local filesystem + SQLite) ---
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed
BOOKS_DIR=./data/books
LOG_DIR=./data/logs
SQLITE_PATH=./data/book_decode.db

# --- Upload limits ---
MAX_EPUB_SIZE_MB=50

# --- LLM provider ---
# openai | anthropic | openai_compatible
LLM_PROVIDER=openai
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192
# Set true for local/demo runs without calling a real model
LLM_MOCK=false

# Anthropic Claude example:
# LLM_PROVIDER=anthropic
# LLM_API_BASE=https://api.anthropic.com
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-20250514

# OpenAI-compatible gateway example (Groq, Together, Ollama, etc.):
# LLM_PROVIDER=openai_compatible
# LLM_API_BASE=https://api.groq.com/openai/v1
# LLM_API_KEY=...
# LLM_MODEL=llama-3.3-70b-versatile

# --- Pipeline controls ---
MAX_CHAPTER_RETRIES=3
RETRY_BACKOFF_SECONDS=2
CHUNK_TOKEN_LIMIT=6000
CHUNK_OVERLAP_BLOCKS=2

# --- Optional IndicTrans2 comparison layer (not the reasoning engine) ---
INDIC_TRANS2_ENABLED=false
INDIC_TRANS2_ENDPOINT=
